# ========================================
# CONFIGURAÇÕES BÁSICAS
# ========================================

# Permitir que o .htaccess funcione
Options +FollowSymLinks -MultiViews -Indexes

# ========================================
# MIME TYPES PRIORITÁRIOS
# ========================================

# Forçar tipo correto ANTES de qualquer processamento
<IfModule mod_mime.c>
  AddType text/plain .txt
  AddType application/xml .xml
  AddType application/json .json
</IfModule>

# ========================================
# ARQUIVOS CRÍTICOS: ads.txt, robots.txt
# ========================================

# ads.txt - Servir diretamente como texto puro
<Files "ads.txt">
  ForceType text/plain
  SetHandler None
  <IfModule mod_headers.c>
    Header set Content-Type "text/plain; charset=utf-8"
    Header set X-Content-Type-Options "nosniff"
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </IfModule>
</Files>

# robots.txt - Servir diretamente como texto puro
<Files "robots.txt">
  ForceType text/plain
  SetHandler None
  <IfModule mod_headers.c>
    Header set Content-Type "text/plain; charset=utf-8"
  </IfModule>
</Files>

# sitemap.xml - Servir diretamente como XML
<Files "sitemap.xml">
  ForceType application/xml
  SetHandler None
  <IfModule mod_headers.c>
    Header set Content-Type "application/xml; charset=utf-8"
  </IfModule>
</Files>

# ========================================
# REWRITE RULES
# ========================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # ========================================
  # ARQUIVOS ESTÁTICOS NA RAIZ - NUNCA REDIRECIONAR
  # ========================================
  
  # ads.txt - CRÍTICO para Google AdSense
  RewriteRule ^ads\.txt$ - [L,T=text/plain]
  
  # robots.txt
  RewriteRule ^robots\.txt$ - [L,T=text/plain]
  
  # sitemap.xml
  RewriteRule ^sitemap\.xml$ - [L,T=application/xml]
  
  # favicon
  RewriteRule ^favicon\.ico$ - [L]
  
  # apple-touch-icon
  RewriteRule ^apple-touch-icon\.png$ - [L]

  # ========================================
  # NORMALIZAÇÃO DE URL: Remover trailing slash
  # ========================================
  
  # Remove trailing slash exceto para a raiz
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} (.+)/$
  RewriteRule ^ %1 [R=301,L]

  # ========================================
  # ARQUIVOS ESTÁTICOS: Servir diretamente
  # ========================================
  
  # Qualquer arquivo de texto
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^.*\.(txt|xml|json|webmanifest)$ - [L]
  
  # Imagens e ícones
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^.*\.(ico|png|jpg|jpeg|gif|svg|webp)$ - [L]
  
  # Fontes
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^.*\.(woff|woff2|ttf|eot|otf)$ - [L]
  
  # Outros arquivos estáticos
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^.*\.(css|js|map|pdf)$ - [L]

  # ========================================
  # SPA: Redirecionar para index.html
  # ========================================
  
  # Se não for arquivo nem diretório existente, redireciona para index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L,QSA]
</IfModule>

# ========================================
# HEADERS GERAIS
# ========================================

<IfModule mod_headers.c>
  # Permitir acesso do Googlebot e outros crawlers
  Header set X-Robots-Tag "index, follow"
  
  # Segurança
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  
  # index.html - Sempre permitir acesso
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>

# ========================================
# PERMISSÕES: Garantir acesso público
# ========================================

<IfModule mod_authz_core.c>
  Require all granted
</IfModule>

# ========================================
# CACHE: Otimizar performance
# ========================================

<IfModule mod_expires.c>
  ExpiresActive On
  
  # Arquivos de texto (sem cache para atualização rápida)
  ExpiresByType text/plain "access plus 0 seconds"
  ExpiresByType application/xml "access plus 0 seconds"
  
  # Imagens (cache longo)
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # CSS e JavaScript (cache médio)
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  
  # Fontes (cache longo)
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>
